# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=user_management
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# MongoDB
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=user_management_audit

# JWT
SECRET_KEY=your-secret-key-change-this-in-production-at-least-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# API
API_V1_STR=/api/v1
PROJECT_NAME=User Management Service
VERSION=0.1.0

# CORS (JSON array format: '["http://localhost:3000","http://localhost:8080"]')
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# Initial Admin User (for seeding)
FIRST_SUPERUSER_EMAIL=admin@example.com
FIRST_SUPERUSER_PASSWORD=admin123
FIRST_SUPERUSER_USERNAME=admin
